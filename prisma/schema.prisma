generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String
  role     String @default("admin")
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  coverImage  String?
  published   Boolean   @default(false)
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        PostTag[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  views       Int       @default(0)
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model Tag {
  id    Int      @id @default(autoincrement())
  name  String   @unique
  slug  String   @unique
  posts PostTag[]
}

model PostTag {
  postId Int  @map("post_id")
  tagId  Int  @map("tag_id")
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Log {
  id         Int      @id @default(autoincrement())
  level      String   @default("info")
  category   String
  action     String
  message    String
  meta       String?
  ip         String?
  userId     Int?
  createdAt  DateTime @default(now())

  @@index([category])
  @@index([level])
  @@index([createdAt])
}

model SiteSetting {
  id              Int      @id @default(1)
  siteName        String   @default("薄云隙")
  siteDescription String?  @default("窥见世界裂隙")
  logoText        String?  @default("隙")
  heroTitle       String?  @default("薄云隙")
  heroSubtitle    String?  @default("窥见世界裂隙 · 数字古风档案馆")
  archiveLabel    String?  @default("云 海 档 案 馆")
  emptyStateText  String?  @default("档案馆中尚无卷宗")
  authorName      String?
  authorBio       String?
  contactEmail    String?
  githubUrl       String?
  copyrightText   String?  @default("薄云隙 · 数字古风档案馆")
  icpNumber       String?
  policeNumber    String?
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  aboutContent    String?
  easterEggLogoEnabled    Boolean  @default(true)
  easterEggLogoClicks     Int      @default(5)
  easterEggLogoText       String?  @default("云深不知处,只在此山中,欲穷千里目,更上一层楼,海内存知己,天涯若比邻")
  easterEggLogoDuration   Int      @default(3)
  easterEggConsoleEnabled Boolean  @default(true)
  easterEggConsoleText    String?  @default("欢迎来到薄云隙 · 窥见世界裂隙")
  easterEggKonamiEnabled  Boolean  @default(true)
  easterEggKonamiText     String?  @default("道可道，非常道。名可名，非常名。")
  easterEggSearchHello    String?  @default("你好，有缘人！既然寻到了此处，便留下吧。")
  updatedAt       DateTime @updatedAt
}
